<Window x:Class="FileRebuilderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileRebuilder"
        Height="500"
        Width="750"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Window.Resources>

        <SolidColorBrush x:Key="AccentColor" Color="#4e004f"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E81123"/>
        <SolidColorBrush x:Key="CardHoverColor" Color="#2D2D30"/>
        <SolidColorBrush x:Key="Background" Color="#FFFFFF"/>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="File Rebuilder"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="{StaticResource TextColor}"/>

        <!-- File Selection -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FilePathTextBox"
                     Padding="5"
                     IsReadOnly="True"
                     VerticalAlignment="Center"/>

            <Button Content="Browse"
                    Width="120"
                    Margin="10,0,0,0"
                    Grid.Column="1"
                    Click="Browse_Click"
                    Foreground="Black"
                    Background="White"
                    BorderBrush="#CCC"/>

            <Button Content="Backup File"
                    Width="120"
                    Margin="10,0,0,0"
                    Grid.Column="2"
                    Click="Backup_Click"
                    Foreground="Black"
                    Background="White"
                    BorderBrush="#CCC"/>
            
        </Grid>

        <!-- Search Bar -->
        <TextBox x:Name="SearchTextBox"
                 Grid.Row="2"
                 Margin="0,0,0,10"
                 Height="28"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextChanged="Search_TextChanged"/>

        <!-- File List -->
        <ListBox x:Name="FilesListBox"
                 Grid.Row="3"
                 Background="{StaticResource CardColor}"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Main container grid for each list item -->
                    <Grid Margin="0,5"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- The card -->
                        <Border Padding="8" CornerRadius="6"
                                BorderBrush="#444" BorderThickness="1"
                                Background="{StaticResource CardColor}"
                                Grid.Column="0">

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource CardColor}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource CardHoverColor}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- File Icon -->
                                <TextBlock Text="📄"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,15,0"
                                           Grid.Column="0"
                                           Foreground="White"/>

                                <!-- File Details -->
                                <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding FileName}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextColor}"
                                   TextWrapping="Wrap"
                                   Grid.Row="0"/>

                                    <TextBlock Text="{Binding OriginalPath}"
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Grid.Row="1"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Delete Button outside the card -->
                        <Button Content="🗑"
                                Width="30"
                                Height="25"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Grid.Column="1"
                                Click="Delete_Click"
                                Cursor="Hand"
                                ToolTip="Delete">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <!-- base -->
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>

                                                    <!-- ✅ Hover now works -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerColor}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>

                                                    <!-- Click -->
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>

                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Restore Button -->
        <Button Grid.Row="4"
                Content="Restore Selected File"
                Height="35"
                Margin="0,15,0,0"
                Click="Restore_Click"
                Foreground="White"
                BorderBrush="{StaticResource AccentColor}">

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                </Style>
            </Button.Style>
        </Button>


    </Grid>
</Window>