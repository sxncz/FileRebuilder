<Window x:Class="FileRebuilderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileRebuilder"
        Height="500"
        Width="750"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="File Rebuilder"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="{StaticResource TextColor}"/>

        <!-- File Selection -->
        <Border Grid.Row="1"
                Padding="10"
                CornerRadius="8"
                BorderBrush="#444"
                BorderThickness="1"
                Background="{StaticResource CardColor}">

            <StackPanel>
                <TextBlock Text="Select File"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"
                           Foreground="{StaticResource TextColor}"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="FilePathTextBox"
                             Width="500"
                             IsReadOnly="True"
                             Padding="5"/>

                    <Button Content="Browse"
                            Width="100"
                            Margin="10,0,0,0"
                            Click="Browse_Click"/>
                </StackPanel>

                <Button Content="Backup File"
                        Margin="0,10,0,0"
                        Height="30"
                        Click="Backup_Click"/>
            </StackPanel>
        </Border>

        <!-- 🔍 SEARCH BAR -->
        <TextBox x:Name="SearchTextBox"
                 Grid.Row="2"
                 Margin="0,10,0,5"
                 Height="28"
                 Padding="5"
                 TextChanged="Search_TextChanged"/>

        <!-- File List -->
        <ListBox x:Name="FilesListBox"
                 Grid.Row="3"
                 Height="220"
                 Background="{StaticResource CardColor}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8"
                            Margin="0,5"
                            CornerRadius="6"
                            BorderBrush="#444"
                            BorderThickness="1"
                            Background="{StaticResource CardColor}">

                        <DockPanel>

                            <TextBlock Text="📄"
                                       FontSize="18"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>

                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{Binding FileName}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextColor}"/>

                                <TextBlock Text="{Binding OriginalPath}"
                                           FontSize="11"
                                           Foreground="Gray"/>
                            </StackPanel>

                            <Button Content="🗑"
                                    Width="30"
                                    Height="25"
                                    Click="Delete_Click"/>
                            
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Restore -->
        <Button Grid.Row="4"
                Content="Restore Selected File"
                Height="35"
                Margin="0,15,0,0"
                Click="Restore_Click"/>
    </Grid>
</Window>