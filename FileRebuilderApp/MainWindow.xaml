<Window x:Class="FileRebuilderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileRebuilder"
        Height="500"
        Width="750"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="File Rebuilder"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="{StaticResource TextColor}"/>

        <!-- File Selection -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FilePathTextBox"
                     Padding="5"
                     IsReadOnly="True"
                     VerticalAlignment="Center"/>

            <Button Content="Browse"
                    Width="120"
                    Margin="10,0,0,0"
                    Grid.Column="1"
                    Click="Browse_Click"/>

            <Button Content="Backup File"
                    Width="120"
                    Margin="10,0,0,0"
                    Grid.Column="2"
                    Click="Backup_Click"/>
        </Grid>

        <!-- Search Bar -->
        <TextBox x:Name="SearchTextBox"
                 Grid.Row="2"
                 Margin="0,0,0,10"
                 Height="28"
                 Padding="5"
                 HorizontalAlignment="Stretch"
                 TextChanged="Search_TextChanged"/>

        <!-- File List -->
        <ListBox x:Name="FilesListBox"
                 Grid.Row="3"
                 Background="{StaticResource CardColor}"
                 BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Main container grid for each list item -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <!-- Card + file details -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Delete button outside -->
                        </Grid.ColumnDefinitions>

                        <!-- The card -->
                        <Border Padding="8" CornerRadius="6"
                    BorderBrush="#444" BorderThickness="1"
                    Background="{StaticResource CardColor}"
                    Grid.Column="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Icon -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- File details -->
                                </Grid.ColumnDefinitions>

                                <!-- File Icon -->
                                <TextBlock Text="📄"
                               FontSize="22"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               Grid.Column="0"/>

                                <!-- File Details -->
                                <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding FileName}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextColor}"
                                   TextWrapping="Wrap"
                                   Grid.Row="0"/>

                                    <TextBlock Text="{Binding OriginalPath}"
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Grid.Row="1"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Delete Button outside the card -->
                        <Button Content="🗑"
                    Width="30"
                    Height="25"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Grid.Column="1"
                    Click="Delete_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Restore Button -->
        <Button Grid.Row="4"
                Content="Restore Selected File"
                Height="35"
                Margin="0,15,0,0"
                Click="Restore_Click"/>
    </Grid>
</Window>